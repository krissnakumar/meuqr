# =============================================================================
# MeuQR — Environment Variables
# =============================================================================
#
# Copy this file to create your environment configuration:
#
#   cp .env.example apps/web/.env.local
#   cp .env.example apps/mobile/.env
#
# =============================================================================

# ---------------------------------------------------------------------------
# Supabase (REQUIRED for both Web & Mobile)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Server-side only — never expose to client (Edge Functions, admin API)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ---------------------------------------------------------------------------
# App (REQUIRED for Web)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=MeuQR

# ---------------------------------------------------------------------------
# Mobile (create a separate apps/mobile/.env with these)
# ---------------------------------------------------------------------------
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ---------------------------------------------------------------------------
# Mercado Pago (optional — for subscriptions)
# ---------------------------------------------------------------------------
MERCADO_PAGO_ACCESS_TOKEN=your_mercado_pago_token
MERCADO_PAGO_PUBLIC_KEY=your_mercado_pago_public_key
MERCADO_PAGO_WEBHOOK_SECRET=your_webhook_secret

# ---------------------------------------------------------------------------
# Sentry (optional — error tracking)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SENTRY_DSN=https://your-dsn@oXXXXX.ingest.sentry.io/XXXXX
SENTRY_AUTH_TOKEN=your-sentry-auth-token
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=your-sentry-project

# ---------------------------------------------------------------------------
# Stripe (optional — future payment provider)
# ---------------------------------------------------------------------------
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret

# ---------------------------------------------------------------------------
# PostHog (optional — product analytics)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_POSTHOG_KEY=your_posthog_key
NEXT_PUBLIC_POSTHOG_HOST=your_posthog_host

# ---------------------------------------------------------------------------
# Upstash Redis (optional — cloud-based rate limiting)
# ---------------------------------------------------------------------------
UPSTASH_REDIS_REST_URL=your_upstash_redis_rest_url
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_rest_token
